{
  "expo": {
    "name": "SalatTracker",
    "slug": "salat-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A1A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.salattracker.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to calculate prayer times.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Used to calculate prayer times."
      }
    },
    "plugins": [
      "expo-sensors"
    ]
  }
}
